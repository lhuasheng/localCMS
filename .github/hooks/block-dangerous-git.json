        "timeout": 10
      },
      {
        "type": "command",
        "command": "python .github/hooks/scripts/block_placeholder_code.py",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "python .github/hooks/scripts/guard_diff_scope.py",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "python .github/hooks/scripts/commit_discipline.py",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "python .github/hooks/scripts/require_test_evidence.py",
        "timeout": 10
      }
    ]
  }

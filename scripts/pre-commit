#!/usr/bin/env bash
# Pre-commit hook: validate Obsidian backlinks before each commit.
# Install with: bash scripts/install-hooks.sh
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if ! command -v cms &> /dev/null; then
    echo "[pre-commit] 'cms' command not found – skipping backlink validation." >&2
    echo "[pre-commit] Run 'pip install -e .' from the repo root to install it." >&2
    exit 0
fi

echo "[pre-commit] Validating backlinks…"
if ! cms --root "$REPO_ROOT" validate-backlinks; then
    echo "[pre-commit] ✗ Broken backlinks detected. Fix the links above before committing." >&2
    exit 1
fi
echo "[pre-commit] ✓ All backlinks resolved."
